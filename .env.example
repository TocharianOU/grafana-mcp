# Grafana server URL (required)
GRAFANA_URL=http://localhost:3000

# Grafana Service Account Token (recommended)
GRAFANA_TOKEN=

# Grafana basic auth username (alternative to token)
GRAFANA_USERNAME=

# Grafana basic auth password (alternative to token)
GRAFANA_PASSWORD=

# Grafana organization ID (optional, defaults to 1)
GRAFANA_ORG_ID=1

# TLS certificate validation: set to '0' to skip (development only)
NODE_TLS_REJECT_UNAUTHORIZED=1

# Maximum tokens per tool call result (default: 20000)
MAX_TOKEN_CALL=20000

# Transport mode: 'stdio' (default) or 'http'
MCP_TRANSPORT=stdio

# HTTP transport settings (only used when MCP_TRANSPORT=http)
MCP_HTTP_PORT=3100
MCP_HTTP_HOST=localhost
