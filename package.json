{
  "name": "@tocharianou/grafana-mcp",
  "description": "Grafana MCP Server with comprehensive API access for dashboards, datasources, alerting, and observability",
  "version": "2.0.0",
  "mcpName": "io.github.TocharianOU/grafana",
  "license": "Apache-2.0",
  "author": "TocharianOU <tocharian139@protonmail.com>",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "bin": {
    "grafana-mcp": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TocharianOU/grafana-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/TocharianOU/grafana-mcp/issues"
  },
  "homepage": "https://github.com/TocharianOU/grafana-mcp#readme",
  "keywords": [
    "grafana",
    "observability",
    "monitoring",
    "mcp",
    "mcp-server"
  ],
  "files": [
    "dist",
    "logos",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "npm run build",
    "release:npm": "npm run build && tar -czf grafana-mcp-v$npm_package_version.tar.gz dist logos LICENSE README.md package.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@types/express": "^5.0.3",
    "express": "^5.1.0",
    "tiktoken": "^1.0.18",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "22.13.15",
    "shx": "0.4.0",
    "typescript": "5.8.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
