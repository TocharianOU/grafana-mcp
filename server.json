{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.TocharianOU/grafana",
  "description": "Grafana MCP Server with comprehensive API access for dashboards, datasources, alerting, annotations, and Prometheus metrics",
  "title": "Grafana",
  "websiteUrl": "https://github.com/TocharianOU/grafana-mcp",
  "repository": {
    "url": "https://github.com/TocharianOU/grafana-mcp",
    "source": "github"
  },
  "version": "2.0.0",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@tocharianou/grafana-mcp",
      "version": "2.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "GRAFANA_URL",
          "description": "Your Grafana instance URL (e.g., http://localhost:3000)",
          "isRequired": true,
          "format": "string"
        },
        {
          "name": "GRAFANA_TOKEN",
          "description": "Grafana Service Account Token for authentication (recommended)",
          "isRequired": false,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "GRAFANA_USERNAME",
          "description": "Grafana username for basic authentication",
          "isRequired": false,
          "format": "string"
        },
        {
          "name": "GRAFANA_PASSWORD",
          "description": "Grafana password for basic authentication",
          "isRequired": false,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "GRAFANA_ORG_ID",
          "description": "Grafana organization ID (defaults to 1)",
          "isRequired": false,
          "format": "number",
          "default": "1"
        },
        {
          "name": "NODE_TLS_REJECT_UNAUTHORIZED",
          "description": "Set to '0' to disable SSL certificate validation (development only)",
          "isRequired": false,
          "format": "string",
          "default": "1"
        },
        {
          "name": "MAX_TOKEN_CALL",
          "description": "Maximum tokens per tool call result (default: 20000)",
          "isRequired": false,
          "format": "number",
          "default": "20000"
        }
      ]
    },
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@tocharianou/grafana-mcp",
      "version": "2.0.0",
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:{MCP_HTTP_PORT}/mcp"
      },
      "environmentVariables": [
        {
          "name": "MCP_TRANSPORT",
          "description": "Transport mode selection",
          "isRequired": true,
          "format": "string",
          "default": "http",
          "choices": ["stdio", "http"]
        },
        {
          "name": "MCP_HTTP_PORT",
          "description": "HTTP server port (when using HTTP transport)",
          "isRequired": false,
          "format": "number",
          "default": "3100"
        },
        {
          "name": "MCP_HTTP_HOST",
          "description": "HTTP server host (when using HTTP transport)",
          "isRequired": false,
          "format": "string",
          "default": "localhost"
        },
        {
          "name": "GRAFANA_URL",
          "description": "Your Grafana instance URL (e.g., http://localhost:3000)",
          "isRequired": true,
          "format": "string"
        },
        {
          "name": "GRAFANA_TOKEN",
          "description": "Grafana Service Account Token for authentication (recommended)",
          "isRequired": false,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "GRAFANA_USERNAME",
          "description": "Grafana username for basic authentication",
          "isRequired": false,
          "format": "string"
        },
        {
          "name": "GRAFANA_PASSWORD",
          "description": "Grafana password for basic authentication",
          "isRequired": false,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "GRAFANA_ORG_ID",
          "description": "Grafana organization ID (defaults to 1)",
          "isRequired": false,
          "format": "number",
          "default": "1"
        },
        {
          "name": "NODE_TLS_REJECT_UNAUTHORIZED",
          "description": "Set to '0' to disable SSL certificate validation (development only)",
          "isRequired": false,
          "format": "string",
          "default": "1"
        },
        {
          "name": "MAX_TOKEN_CALL",
          "description": "Maximum tokens per tool call result (default: 20000)",
          "isRequired": false,
          "format": "number",
          "default": "20000"
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "tool": "manual",
      "version": "2.0.0",
      "features": {
        "transport_modes": ["stdio", "http"],
        "security_focused": true,
        "grafana_api_coverage": "comprehensive"
      }
    }
  }
}
